# ============================================================
# Agent Survivor — Go Server Environment Variables
# ============================================================
# Copy to .env and adjust values for your environment.

# HTTP/WS listen port (default: 8000)
# Railway auto-sets this via $PORT
PORT=8000

# Allowed CORS origins (comma-separated)
# Development: http://localhost:3000
# Production: https://snake-tonexus.vercel.app
CORS_ORIGIN=http://localhost:3000

# Game tick rate in Hz (default: 20, do not change unless testing)
TICK_RATE=20

# Maximum number of game rooms (default: 5)
MAX_ROOMS=5

# Environment: "development" or "production"
ENV=development
