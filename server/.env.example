# ============================================================
# AI World War v11 — Server Environment Variables
# ============================================================
# Copy to .env and adjust values for your environment.
# Railway auto-sets PORT. All others must be configured.

# ---- Core Server ----

# HTTP/WS listen port (default: 8000)
# Railway auto-sets this via $PORT
PORT=8000

# Allowed CORS origins (comma-separated)
# Development: http://localhost:3000
# Production: https://snake-tonexus.vercel.app
CORS_ORIGIN=http://localhost:3000

# Game tick rate in Hz (default: 20, do not change unless testing)
TICK_RATE=20

# Maximum number of v10 game rooms (default: 5, backward compat)
MAX_ROOMS=5

# Environment: "development" or "production"
ENV=development

# ---- Authentication (S03) ----

# JWT signing secret (MUST be 32+ chars in production)
JWT_SECRET=dev-secret-change-in-production

# ---- Redis (S02) ----

# Redis connection (optional — server runs without Redis)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ---- PostgreSQL (S01) ----

# PostgreSQL direct connection (Railway standard)
# Used by PGPool for direct pgx access (parallel to Supabase REST)
DATABASE_URL=postgres://user:pass@host:port/dbname

# ---- Observability (S44) ----

# Webhook URL for error alerts (Slack/Discord webhook)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ---- Railway Deployment ----

# Railway auto-sets these:
# PORT — HTTP listen port
# RAILWAY_ENVIRONMENT — "production"
# RAILWAY_PUBLIC_DOMAIN — public URL

# ---- Vercel Frontend ----

# Set in Vercel dashboard:
# NEXT_PUBLIC_SERVER_URL=https://snake-production-3b4e.up.railway.app

# ---- v30 Phase 2: Token Economy (Forge Price Feed) ----

# Forge Pool API URL for $AWW token price polling (Task 2-1)
# Leave empty to use GDP-based simulation pricing as fallback.
# FORGE_API_URL=https://api.forge.trade

# JSON file path for token economy persistence (Task 2-10)
# Server saves balances/rewards every 30 minutes; loads on startup.
TOKEN_PERSIST_FILE=data/token_economy.json

# Default season end time (Unix ms) for staking calculations (Task 2-16)
# Set to actual season end time in production.
# SEASON_END_TIME=1748736000000
